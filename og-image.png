from PIL import Image, ImageDraw, ImageFont

W, H = 1200, 630
BG = (11, 17, 32)
PANEL = (18, 27, 46)
LINE = (36, 48, 74)
TEXT = (228, 233, 242)
TEXT_DIM = (147, 161, 188)
ACCENT = (255, 138, 61)
SAFE = (45, 212, 191)

img = Image.new("RGB", (W, H), BG)
d = ImageDraw.Draw(img, "RGBA")

grid = 44
for x in range(0, W, grid):
    d.line([(x, 0), (x, H)], fill=LINE + (60,), width=1)
for y in range(0, H, grid):
    d.line([(0, y), (W, y)], fill=LINE + (60,), width=1)

d.rectangle([0, 0, W, H], outline=None)
fade = Image.new("L", (W, H), 0)
fd = ImageDraw.Draw(fade)
for i in range(H):
    alpha = max(0, 255 - int(i * 0.7))
    fd.line([(0, i), (W, i)], fill=alpha)
dark_overlay = Image.new("RGB", (W, H), BG)
img = Image.composite(img, dark_overlay, fade)
d = ImageDraw.Draw(img, "RGBA")

mono_bold = "/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf"
mono = "/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf"
sans_bold = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
sans = "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"

f_logo = ImageFont.truetype(sans_bold, 30)
f_h1 = ImageFont.truetype(sans_bold, 58)
f_sub = ImageFont.truetype(sans, 26)
f_mono = ImageFont.truetype(mono, 20)
f_tag = ImageFont.truetype(mono_bold, 18)

margin = 80

d.ellipse([margin, 66, margin + 14, 80], fill=SAFE)
d.text((margin + 26, 56), "STARKER SECURITY", font=f_logo, fill=TEXT)

term_x, term_y, term_w, term_h = margin, 150, 520, 130
d.rounded_rectangle([term_x, term_y, term_x + term_w, term_y + term_h], radius=10, fill=PANEL, outline=LINE, width=1)
for i, cx in enumerate([term_x + 22, term_x + 42, term_x + 62]):
    d.ellipse([cx, term_y + 20, cx + 10, term_y + 30], fill=LINE)
d.text((term_x + 22, term_y + 46), "$ starker scan --target=rede-cliente", font=f_mono, fill=TEXT_DIM)
d.text((term_x + 22, term_y + 74), "→ 11 hosts · 3 serviços expostos", font=f_mono, fill=TEXT_DIM)
d.text((term_x + 22, term_y + 102), "✓ termo de autorização assinado", font=f_mono, fill=SAFE)

y1 = 320
d.text((margin, y1), "Pentest ético e auditoria", font=f_h1, fill=TEXT)
d.text((margin, y1 + 68), "de segurança ", font=f_h1, fill=TEXT)
w_seg = d.textlength("de segurança ", font=f_h1)
d.text((margin + w_seg, y1 + 68), "ofensiva", font=f_h1, fill=ACCENT)

d.text((margin, y1 + 150), "Testes de invasão com contrato, escopo definido e relatório", font=f_sub, fill=TEXT_DIM)
d.text((margin, y1 + 184), "profissional para LGPD, ISO 27001 e PCI-DSS.", font=f_sub, fill=TEXT_DIM)

tag_y = H - 70
tags = ["LGPD", "ISO 27001", "PCI-DSS"]
tx = margin
for t in tags:
    tw = d.textlength(t, font=f_tag) + 28
    d.rounded_rectangle([tx, tag_y, tx + tw, tag_y + 34], radius=17, outline=ACCENT, width=1)
    d.text((tx + 14, tag_y + 8), t, font=f_tag, fill=ACCENT)
    tx += tw + 14

img.save("/home/claude/og-image.png")
print("done", img.size)
